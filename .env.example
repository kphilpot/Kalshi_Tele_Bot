# Telegram Bot
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID (see DEPLOYMENT.md for how to find this)
TELEGRAM_CHAT_ID=

# Kalshi account credentials
KALSHI_EMAIL=
KALSHI_PASSWORD=

# Optional: override the directory where daily state JSON files are stored
# Defaults to ./state relative to bot.py
# STATE_DIR=/opt/kalshi-weather-bot/state
